# Supabase Configuration (automatically configured by Lovable Cloud)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# Google reCAPTCHA v2
# Get your keys at: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Design Partner serverless functions (api/slots.ts, api/apply.ts).
# Server-only. Never expose SUPABASE_SERVICE_ROLE_KEY to the client bundle.
# The service role bypasses RLS, so scope it to this project's tables only.
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Design Partner cohort visibility. Set to "false" to hide the countdown and
# dated copy if product readiness slips. Page falls back to waitlist-only CTA.
VITE_COHORT_VISIBLE=true

# Top announcement banner visibility (fundraise CTA). Set to "false" to hide
# the banner without removing the component. Default: visible.
VITE_ANNOUNCE_VISIBLE=true
